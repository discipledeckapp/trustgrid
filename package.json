{
  "name": "trustgrid",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate --filter=backend",
    "db:seed": "turbo run db:seed --filter=backend"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "browserslist": "^4.28.2",
    "caniuse-lite": "1.0.30001579",
    "fast-glob": "^3.3.3"
  }
}
