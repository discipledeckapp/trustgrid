# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trustgrid?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-strong-random-secret-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003"

# ─── Redis (Upstash free tier) ─────────────────────────────────────────────────
# Get from: upstash.com → Create Redis → copy REST URL (starts with rediss://)
REDIS_URL="redis://localhost:6379"

# ─── Sentry (free tier) ────────────────────────────────────────────────────────
# Get from: sentry.io → New Project → Node.js → copy DSN
SENTRY_DSN=""

# ─── Identity Verification ─────────────────────────────────────────────────────
# MOCK = development (no real verification, always passes)
# LIVE = production (uses Prembly for NG, Manual fallback for others)
IDENTITY_ADAPTER=MOCK

# Prembly IdentityPass — https://app.prembly.com → API Keys
# Required for NIN, BVN, and CAC verification in Nigeria
# Leave blank to use MOCK adapter; workers will be flagged UNVERIFIED, NOT blocked
PREMBLY_API_KEY=
PREMBLY_APP_ID=

# ─── Encryption & Privacy ───────────────────────────────────────────────────────
# ENCRYPTION_KEY: 32-byte hex (64 chars) — AES-256-GCM for PII fields (name, DOB, photo)
# ID_HASH_SECRET: 32-byte hex (64 chars) — HMAC-SHA256 for NIN/BVN deduplication
#
# Why two separate secrets?
#   ENCRYPTION_KEY: used to encrypt/decrypt stored PII (name, DOB, photo)
#   ID_HASH_SECRET: used to HASH identity numbers for deduplication
#   Keeping them separate means you can rotate one without invalidating the other.
#
# Plain SHA-256 of NIN is vulnerable to rainbow table attacks (NIN = 11 digits,
# ~100B possibilities — precomputable in seconds). HMAC with a secret key prevents this.
# Without ID_HASH_SECRET, the service falls back to SHA-256 with a logged warning.
#
# Generate in terminal:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
ID_HASH_SECRET=

# ─── Termii — SMS + WhatsApp Notifications ────────────────────────────────────
# Get from: termii.com → API → Live API Key
# Used for: assignment alerts, verification updates, emergency mobilisation
# Graceful: if not configured, notifications are logged but not sent
TERMII_API_KEY=
TERMII_SENDER_ID=TrustGrid
TERMII_WHATSAPP_SENDER=TrustGrid

# ─── Zeptomail (Transactional Email) ─────────────────────────────────────────
# Get from: mail.zoho.com/zm/settings → Developer
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=noreply@mobiris.ng
ZEPTOMAIL_FROM_NAME=TrustGrid

# ─── Paystack (Subscription + Payment) ──────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys & Webhooks
# Webhook: add https://api.trustgrid.ng/api/v1/billing/webhook in Paystack dashboard
# If not configured: payment endpoints return 400 gracefully, rest of platform works
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://api.trustgrid.ng/api/v1/billing/callback

# ─── Amazon Rekognition — Face Liveness ─────────────────────────────────────────
# Used ONLY for liveness detection (is this a real live person?).
# Prembly handles face-to-NIN photo comparison separately.
# If not configured, liveness step is skipped; worker proceeds as PARTIALLY_VERIFIED.
# IAM permissions required: rekognition:CreateFaceLivenessSession, rekognition:GetFaceLivenessSessionResults
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=trustgrid-documents

# ─── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=
