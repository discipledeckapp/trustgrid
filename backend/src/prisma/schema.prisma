// TrustGrid Prisma Schema
// Community Workforce & Service Governance Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum InstitutionType {
  ESTATE
  CHURCH
  SCHOOL
  UNIVERSITY
  CONVENTION_ORGANIZER
  FACILITY_MANAGER
  SMART_CITY_OPERATOR
  LOCAL_GOVERNMENT
  CORPORATE
  NGO
}

enum UserRole {
  PLATFORM_ADMIN
  INSTITUTION_ADMIN
  INSTITUTION_OPERATOR
  INSTITUTION_VIEWER
  ORGANISATION_ADMIN
  ORGANISATION_MANAGER
  WORKER
  VENDOR_REPRESENTATIVE
  RESIDENT
}

enum OrganisationType {
  SOLE_PROPRIETOR
  LIMITED_LIABILITY
  PARTNERSHIP
  NGO
  COOPERATIVE
  STAFFING_AGENCY
  FACILITIES_COMPANY
  SECURITY_COMPANY
  CLEANING_COMPANY
  OTHER
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_MORE_INFO
  APPROVED
  REJECTED
  ACTIVE
  SUSPENDED
}

enum OnboardingType {
  INDIVIDUAL_WORKER
  ORGANISATION
  BRANCH
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  PARTIALLY_VERIFIED
  FULLY_VERIFIED
  VERIFICATION_FAILED
  SUSPENDED
}

enum TrustEventType {
  ACCOUNT_CREATED
  IDENTITY_VERIFIED
  CREDENTIAL_VERIFIED
  DEPLOYMENT_COMPLETED
  DEPLOYMENT_ABANDONED
  RATING_SUBMITTED
  ENDORSEMENT_ADDED
  ENDORSEMENT_REMOVED
  INCIDENT_RAISED
  INCIDENT_RESOLVED
  INCIDENT_DISMISSED
  INACTIVITY_PENALTY
  MANUAL_ADJUSTMENT
  SUSPENSION
  REINSTATEMENT
}

enum ServiceRequestStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
  ESCALATED
}

enum AssignmentStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
  ACTIVE
  COMPLETED
  ABANDONED
  TERMINATED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  UNDER_INVESTIGATION
  PENDING_RESOLUTION
  RESOLVED
  DISMISSED
  ESCALATED
}

enum ProcurementStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkerType {
  CONTRACTOR
  FREELANCER
  EMPLOYEE
  VOLUNTEER
  INTERN
}

enum JoinPolicy {
  OPEN
  REQUEST
  INVITE_ONLY
}

// ═══════════════════════════════════════════════════════
// INSTITUTION (TENANT)
// ═══════════════════════════════════════════════════════

model Institution {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  type        InstitutionType
  email       String          @unique
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String          @default("NG")
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean         @default(true)
  isVerified  Boolean         @default(false)
  subdomain           String?   @unique  // "rccg" → rccg.trustgrid.ng
  customDomain        String?   @unique  // "portal.rccg.org" (Enterprise)
  brandConfig         Json      @default("{}")  // colors, logo, name, tagline
  subdomainEnabled    Boolean   @default(false)
  customDomainEnabled Boolean   @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  config             InstitutionConfig?
  userAccounts       UserAccount[]
  workerProfiles     WorkerProfile[]
  vendorProfiles     VendorProfile[]
  volunteerProfiles  VolunteerProfile[]
  organisations      Organisation[]
  onboardingApps     OnboardingApplication[]
  serviceRequests    ServiceRequest[]
  assignments        WorkforceAssignment[]
  trustEvents        TrustEvent[]
  incidents          IncidentReport[]
  endorsements       Endorsement[]
  procurements       ProcurementRequest[]
  performanceReviews PerformanceReview[]

  @@map("institutions")
}

model InstitutionConfig {
  id            String  @id @default(cuid())
  institutionId String  @unique

  trustScoreWeights       Json    @default("{}")
  trustScoreTimeDecayDays Int     @default(365)
  minimumTrustScore       Int     @default(50)

  requireIdentityVerification  Boolean  @default(true)
  requireFaceMatch             Boolean  @default(false)
  allowedIdentityProviders     String[] @default(["NIN"])

  endorsementsRequiredForActivation Int @default(0)
  endorsementsRequiredForHighTrust  Int @default(3)

  serviceCategories   Json @default("[]")
  workforceCategories Json @default("[]")
  slaRules            Json @default("{}")
  escalationRules     Json @default("{}")
  serviceZones        Json @default("[]")
  notificationChannels Json @default("{}")

  joinPolicy      JoinPolicy @default(REQUEST)
  allowSelfSignup Boolean    @default(true)

  primaryColor  String?
  customDomain  String?
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("institution_configs")
}

// ═══════════════════════════════════════════════════════
// USER ACCOUNT
// ═══════════════════════════════════════════════════════

model UserAccount {
  id              String    @id @default(cuid())
  institutionId   String
  email           String?
  phone           String
  phoneVerified   Boolean   @default(false)
  emailVerified   Boolean   @default(false)
  passwordHash    String?
  role            UserRole
  firstName       String
  lastName        String
  profilePhotoUrl String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  institution     Institution    @relation(fields: [institutionId], references: [id])
  workerProfile   WorkerProfile?
  refreshTokens   RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs       AuditLog[]

  @@unique([institutionId, phone])
  @@unique([institutionId, email])
  @@map("user_accounts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user UserAccount @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  otp       String    // 6-digit code
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════════════════════
// WORKER PROFILE
// ═══════════════════════════════════════════════════════

model WorkerProfile {
  id                   String             @id @default(cuid())
  institutionId        String
  userId               String             @unique
  workerType           WorkerType         @default(CONTRACTOR)
  primarySkill         String
  skills               String[]
  categoryIds          String[]
  isAvailable          Boolean            @default(true)
  availabilityNotes    String?
  serviceZoneIds       String[]
  hourlyRate           Float?
  dailyRate            Float?
  currency             String             @default("NGN")
  verificationStatus   VerificationStatus @default(UNVERIFIED)
  trustScore           Float              @default(0)
  trustScoreUpdatedAt  DateTime?
  totalDeployments     Int                @default(0)
  completedDeployments Int                @default(0)
  averageRating        Float?
  totalEndorsements    Int                @default(0)
  bio                  String?
  yearsExperience      Int?

  // ── Profile photo (stored for ALL workers, verified or not) ──────────
  // Encrypted base64 JPEG — served via /workers/:id/photo endpoint
  // Updated from live selfie during onboarding/verification
  // Agent-assisted onboarding: agent uploads photo on worker's behalf
  profilePhotoEncrypted String?           // AES-256-GCM encrypted base64 JPEG
  profilePhotoHash      String?           // SHA-256 of photo (tamper detection)

  isActive             Boolean            @default(true)
  joinedAt             DateTime           @default(now())
  lastActiveAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  institution          Institution          @relation(fields: [institutionId], references: [id])
  user                 UserAccount          @relation(fields: [userId], references: [id])
  identityVerification IdentityVerification?
  credentials          CredentialRecord[]
  documents            DocumentRecord[]
  trustEvents          TrustEvent[]
  endorsementsReceived Endorsement[]        @relation("EndorsedWorker")
  assignmentWorkers    AssignmentWorker[]
  performanceReviews   PerformanceReview[]  @relation("ReviewedWorker")
  incidents            IncidentReport[]     @relation("WorkerIncident")
  organisationWorkers  OrganisationWorker[]

  @@index([institutionId, isActive])
  @@index([institutionId, trustScore])
  @@index([institutionId, primarySkill])
  @@map("worker_profiles")
}

// ═══════════════════════════════════════════════════════
// VENDOR PROFILE
// ═══════════════════════════════════════════════════════

model VendorProfile {
  id                 String             @id @default(cuid())
  institutionId      String
  companyName        String
  rcNumber           String?
  taxId              String?
  email              String?
  phone              String
  address            String?
  serviceCategories  String[]
  verificationStatus VerificationStatus @default(UNVERIFIED)
  trustScore         Float              @default(0)
  totalContracts     Int                @default(0)
  completedContracts Int                @default(0)
  averageRating      Float?
  isPreferred        Boolean            @default(false)
  isBlacklisted      Boolean            @default(false)
  blacklistReason    String?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  institution        Institution          @relation(fields: [institutionId], references: [id])
  procurements       ProcurementRequest[]
  incidents          IncidentReport[]     @relation("VendorIncident")
  performanceReviews PerformanceReview[]  @relation("ReviewedVendor")
  trustEvents        TrustEvent[]         @relation("VendorTrustEvent")

  @@map("vendor_profiles")
}

// ═══════════════════════════════════════════════════════
// VOLUNTEER PROFILE
// ═══════════════════════════════════════════════════════

model VolunteerProfile {
  id                 String             @id @default(cuid())
  institutionId      String
  firstName          String
  lastName           String
  phone              String
  email              String?
  skills             String[]
  trainingRecords    Json               @default("[]")
  verificationStatus VerificationStatus @default(UNVERIFIED)
  totalDeployments   Int                @default(0)
  isAvailable        Boolean            @default(true)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])

  @@map("volunteer_profiles")
}

// ═══════════════════════════════════════════════════════
// ORGANISATION & BRANCH
// ═══════════════════════════════════════════════════════

model Organisation {
  id                  String           @id @default(cuid())
  institutionId       String
  name                String
  slug                String
  type                OrganisationType @default(OTHER)
  rcNumber            String?
  taxId               String?
  email               String?
  phone               String
  address             String?
  city                String?
  state               String?
  country             String           @default("NG")
  logoUrl             String?
  websiteUrl          String?
  description         String?
  serviceCategories   String[]
  serviceZoneIds      String[]
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  onboardingStatus    OnboardingStatus   @default(DRAFT)
  trustScore          Float              @default(0)
  totalContracts      Int                @default(0)
  completedContracts  Int                @default(0)
  averageRating       Float?
  isPreferred         Boolean            @default(false)
  isBlacklisted       Boolean            @default(false)
  blacklistReason     String?
  isActive            Boolean            @default(true)
  adminUserId         String?
  reviewedById        String?
  reviewedAt          DateTime?
  reviewNotes         String?

  // ── Organisation authorisation ─────────────────────────────────────────
  // Validates that the person registering actually represents the company.
  // CAC check: Prembly returns directors[] — we cross-reference registrant NIN
  // against listed directors. If not a director, an authorisation letter is required.
  representativeNinHash   String?    // HMAC hash of representative's NIN (never plaintext)
  representativeIsDirector Boolean?  // true if NIN matched a CAC-listed director
  authorisationLetterUploaded Boolean @default(false)  // fallback if not a director
  authorisationVerifiedAt DateTime?  // when an admin confirmed the authorisation
  cacDirectors           Json?       // encrypted director names from CAC (for reference)

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  institution  Institution           @relation(fields: [institutionId], references: [id])
  branches     OrganisationBranch[]
  workers      OrganisationWorker[]
  documents    OrganisationDocument[]

  @@unique([institutionId, slug])
  @@index([institutionId, isActive])
  @@map("organisations")
}

model OrganisationBranch {
  id             String   @id @default(cuid())
  organisationId String
  institutionId  String
  name           String
  address        String?
  city           String?
  state          String?
  serviceZoneIds String[]
  managerUserId  String?
  managerName    String?
  managerPhone   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation        @relation(fields: [organisationId], references: [id])
  workers      OrganisationWorker[]

  @@map("organisation_branches")
}

model OrganisationWorker {
  id             String   @id @default(cuid())
  organisationId String
  branchId       String?
  workerId       String
  role           String   @default("WORKER")
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  isActive       Boolean  @default(true)

  organisation Organisation        @relation(fields: [organisationId], references: [id])
  branch       OrganisationBranch? @relation(fields: [branchId], references: [id])
  worker       WorkerProfile       @relation(fields: [workerId], references: [id])

  @@unique([organisationId, workerId])
  @@map("organisation_workers")
}

model OrganisationDocument {
  id             String   @id @default(cuid())
  organisationId String
  documentType   String
  fileName       String
  storageKey     String
  mimeType       String
  isVerified     Boolean  @default(false)
  verifiedAt     DateTime?
  uploadedAt     DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@map("organisation_documents")
}

// ═══════════════════════════════════════════════════════
// ONBOARDING APPLICATION
// ═══════════════════════════════════════════════════════

model OnboardingApplication {
  id              String          @id @default(cuid())
  institutionId   String
  type            OnboardingType
  status          OnboardingStatus @default(DRAFT)

  // Applicant info
  firstName       String?
  lastName        String?
  phone           String
  email           String?
  primarySkill    String?
  organisationName String?

  // Step completion tracking
  stepCompleted   Int              @default(0)  // 0-5 for individual, 0-4 for org
  formData        Json             @default("{}")

  // Review
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  rejectionReason String?

  // Result
  workerId        String?          @unique
  organisationId  String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  institution     Institution      @relation(fields: [institutionId], references: [id])

  @@index([institutionId, status])
  @@index([phone])
  @@map("onboarding_applications")
}

// ═══════════════════════════════════════════════════════
// IDENTITY VERIFICATION
// ═══════════════════════════════════════════════════════

model IdentityVerification {
  id              String             @id @default(cuid())
  workerId        String             @unique
  providerName    String
  countryCode     String             @default("NG")

  // NIN/ID number stored as hash only — never plaintext after processing
  idNumber        String             // encrypted at rest via EncryptionService
  idNumberHash    String             // SHA-256 — used for deduplication only

  status          VerificationStatus @default(PENDING)
  verifiedAt      DateTime?
  failureReason   String?
  providerReference String?          // Prembly verification reference UUID

  // ── Privacy-minimal biographic data (AES-256-GCM encrypted) ─────────
  // Only what is needed to display trust signals and confirm identity.
  // Consent-gated: only shown when worker has applied for an assignment.
  //
  // Stored:   legal name, DOB, gender
  // NOT stored: religion, education, marital status, NOK details,
  //             address, parent names, signature, NIN photo
  verifiedLegalName String?          // encrypted: "Chukwuemeka Adeyemi"
  verifiedDOB       String?          // encrypted: "1990-01-15"
  verifiedGender    String?          // encrypted: "m" / "f"

  // ── Photos ───────────────────────────────────────────────────────────
  // Live selfie: taken during liveness check — shown as profile photo
  // (more recent than NIMC photo; proves current appearance)
  livePhotoEncrypted String?          // encrypted base64 JPEG
  livePhotoHash      String?          // SHA-256 hash for tamper detection

  // NIMC photo: NOT stored — used only for face comparison, then discarded
  // (only the match score is kept, not the biometric image itself)

  // ── Face match result ─────────────────────────────────────────────────
  faceMatchScore  Float?             // 0–100 (not PII — just a confidence score)
  faceMatchPassed Boolean?

  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  worker WorkerProfile @relation(fields: [workerId], references: [id])

  @@map("identity_verifications")
}

model CredentialRecord {
  id               String   @id @default(cuid())
  workerId         String
  credentialType   String
  issuingBody      String
  credentialNumber String?
  issuedAt         DateTime?
  expiresAt        DateTime?
  isVerified       Boolean  @default(false)
  verifiedAt       DateTime?
  documentUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  worker WorkerProfile @relation(fields: [workerId], references: [id])

  @@map("credential_records")
}

model DocumentRecord {
  id            String   @id @default(cuid())
  workerId      String
  documentType  String
  fileName      String
  storageKey    String
  mimeType      String
  fileSizeBytes Int
  isVerified    Boolean  @default(false)
  uploadedAt    DateTime @default(now())

  worker WorkerProfile @relation(fields: [workerId], references: [id])

  @@map("document_records")
}

// ═══════════════════════════════════════════════════════
// TRUST ENGINE
// ═══════════════════════════════════════════════════════

model TrustEvent {
  id            String         @id @default(cuid())
  institutionId String
  workerId      String?
  vendorId      String?
  eventType     TrustEventType
  delta         Float
  weightApplied Float
  referenceType String?
  referenceId   String?
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now())
  createdBy     String?

  institution Institution    @relation(fields: [institutionId], references: [id])
  worker      WorkerProfile? @relation(fields: [workerId], references: [id])
  vendor      VendorProfile? @relation("VendorTrustEvent", fields: [vendorId], references: [id])

  @@index([workerId, institutionId])
  @@index([institutionId, createdAt])
  @@map("trust_events")
}

model Endorsement {
  id            String   @id @default(cuid())
  institutionId String
  workerId      String
  endorsedById  String?
  endorserName  String
  endorserRole  String?
  comment       String?
  weight        Float    @default(1.0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  revokedAt     DateTime?
  revokedReason String?

  institution Institution   @relation(fields: [institutionId], references: [id])
  worker      WorkerProfile @relation("EndorsedWorker", fields: [workerId], references: [id])

  @@map("endorsements")
}

// ═══════════════════════════════════════════════════════
// SERVICE REQUESTS
// ═══════════════════════════════════════════════════════

model ServiceRequest {
  id                String               @id @default(cuid())
  institutionId     String
  requesterId       String
  title             String
  description       String
  categoryId        String
  requiredSkills    String[]
  workersNeeded     Int                  @default(1)
  minimumTrustScore Float?
  scheduledStartAt  DateTime?
  scheduledEndAt    DateTime?
  estimatedHours    Float?
  locationAddress   String?
  locationZoneId    String?
  status            ServiceRequestStatus @default(DRAFT)
  priority          String               @default("NORMAL")
  slaDeadlineAt     DateTime?
  escalatedAt       DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  completedAt       DateTime?
  cancelledAt       DateTime?

  institution        Institution          @relation(fields: [institutionId], references: [id])
  assignment         WorkforceAssignment?
  performanceReviews PerformanceReview[]

  @@index([institutionId, status])
  @@index([institutionId, createdAt])
  @@map("service_requests")
}

// ═══════════════════════════════════════════════════════
// WORKFORCE ASSIGNMENT
// ═══════════════════════════════════════════════════════

model WorkforceAssignment {
  id               String           @id @default(cuid())
  institutionId    String
  serviceRequestId String           @unique
  title            String
  assignedById     String
  status           AssignmentStatus @default(PENDING_ACCEPTANCE)
  startedAt        DateTime?
  completedAt      DateTime?
  supervisorNotes  String?
  completionNotes  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  institution       Institution        @relation(fields: [institutionId], references: [id])
  serviceRequest    ServiceRequest     @relation(fields: [serviceRequestId], references: [id])
  assignmentWorkers AssignmentWorker[]

  @@map("workforce_assignments")
}

model AssignmentWorker {
  id           String           @id @default(cuid())
  assignmentId String
  workerId     String
  role         String           @default("WORKER")
  status       AssignmentStatus @default(PENDING_ACCEPTANCE)
  acceptedAt   DateTime?
  declinedAt   DateTime?
  declineReason String?
  startedAt    DateTime?
  completedAt  DateTime?
  checkInAt    DateTime?
  checkOutAt   DateTime?
  createdAt    DateTime         @default(now())

  assignment WorkforceAssignment @relation(fields: [assignmentId], references: [id])
  worker     WorkerProfile       @relation(fields: [workerId], references: [id])

  @@unique([assignmentId, workerId])
  @@map("assignment_workers")
}

// ═══════════════════════════════════════════════════════
// PROCUREMENT
// ═══════════════════════════════════════════════════════

model ProcurementRequest {
  id              String            @id @default(cuid())
  institutionId   String
  requestedById   String
  title           String
  description     String
  categoryId      String
  estimatedBudget Float?
  currency        String            @default("NGN")
  vendorId        String?
  status          ProcurementStatus @default(DRAFT)
  requiredByDate  DateTime?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  institution Institution          @relation(fields: [institutionId], references: [id])
  vendor      VendorProfile?       @relation(fields: [vendorId], references: [id])
  lineItems   ProcurementLineItem[]
  approvals   ProcurementApproval[]

  @@map("procurement_requests")
}

model ProcurementLineItem {
  id            String             @id @default(cuid())
  procurementId String
  description   String
  quantity      Float
  unitPrice     Float?
  totalPrice    Float?

  procurement ProcurementRequest @relation(fields: [procurementId], references: [id])

  @@map("procurement_line_items")
}

model ProcurementApproval {
  id            String             @id @default(cuid())
  procurementId String
  approvedById  String
  decision      String
  comment       String?
  decidedAt     DateTime           @default(now())

  procurement ProcurementRequest @relation(fields: [procurementId], references: [id])

  @@map("procurement_approvals")
}

// ═══════════════════════════════════════════════════════
// PERFORMANCE & INCIDENTS
// ═══════════════════════════════════════════════════════

model PerformanceReview {
  id                   String   @id @default(cuid())
  institutionId        String
  serviceRequestId     String?
  workerId             String?
  vendorId             String?
  reviewedById         String
  overallRating        Float
  qualityRating        Float?
  punctualityRating    Float?
  communicationRating  Float?
  comment              String?
  isPublic             Boolean  @default(true)
  createdAt            DateTime @default(now())

  institution    Institution     @relation(fields: [institutionId], references: [id])
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
  worker         WorkerProfile?  @relation("ReviewedWorker", fields: [workerId], references: [id])
  vendor         VendorProfile?  @relation("ReviewedVendor", fields: [vendorId], references: [id])

  @@map("performance_reviews")
}

model IncidentReport {
  id              String           @id @default(cuid())
  institutionId   String
  workerId        String?
  vendorId        String?
  reportedById    String
  title           String
  description     String
  severity        IncidentSeverity @default(MEDIUM)
  status          IncidentStatus   @default(OPEN)
  incidentDate    DateTime
  locationAddress String?
  assignedToId    String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  institution Institution    @relation(fields: [institutionId], references: [id])
  worker      WorkerProfile? @relation("WorkerIncident", fields: [workerId], references: [id])
  vendor      VendorProfile? @relation("VendorIncident", fields: [vendorId], references: [id])
  resolution  IncidentResolution?
  notes       IncidentNote[]

  @@map("incident_reports")
}

model IncidentNote {
  id         String         @id @default(cuid())
  incidentId String
  authorId   String
  content    String
  isInternal Boolean        @default(false)
  createdAt  DateTime       @default(now())

  incident IncidentReport @relation(fields: [incidentId], references: [id])

  @@map("incident_notes")
}

model IncidentResolution {
  id               String         @id @default(cuid())
  incidentId       String         @unique
  resolvedById     String
  outcome          String
  summary          String
  trustScoreImpact Float?
  resolvedAt       DateTime       @default(now())

  incident IncidentReport @relation(fields: [incidentId], references: [id])

  @@map("incident_resolutions")
}

// ═══════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════

model AuditLog {
  id            String   @id @default(cuid())
  institutionId String?
  userId        String?
  action        String
  entityType    String
  entityId      String
  previousState Json?
  newState      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  user UserAccount? @relation(fields: [userId], references: [id])

  @@index([institutionId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════
// PLATFORM CATALOG
// ═══════════════════════════════════════════════════════
// The master catalog of service categories managed by Platform Admin.
// Institutions choose which categories apply to them and can set
// institution-specific overrides (different min trust score, etc.)

model PlatformCatalogDomain {
  id          String   @id @default(cuid())
  name        String   @unique   // "Professional Services", "Technical & Trades"
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  PlatformCatalogCategory[]

  @@map("platform_catalog_domains")
}

model PlatformCatalogCategory {
  id                    String   @id @default(cuid())
  domainId              String
  name                  String                      // "Corporate Lawyer", "Electrical"
  slug                  String   @unique            // "corporate-lawyer", "electrical"
  description           String?
  icon                  String?
  color                 String?  @default("#6B7280")
  skills                String[] @default([])       // list of skill tags
  requiredCertifications String[] @default([])      // e.g. ["COREN","NBA Membership"]
  allowedWorkerTypes    String[] @default(["CONTRACTOR","FREELANCER"])
  defaultMinTrustScore  Int      @default(50)
  isProfessional        Boolean  @default(false)    // professional vs artisan
  requiresLicence       Boolean  @default(false)
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String?  // platform admin user ID

  domain                PlatformCatalogDomain  @relation(fields: [domainId], references: [id])
  institutionOverrides  InstitutionCatalogOverride[]

  @@index([domainId, isActive])
  @@map("platform_catalog_categories")
}

// Institution-level override for a catalog category
// Lets institutions keep the platform defaults but adjust min trust score,
// or disable categories that don't apply to their context
model InstitutionCatalogOverride {
  id            String   @id @default(cuid())
  institutionId String
  categoryId    String
  isEnabled     Boolean  @default(true)
  minTrustScore Int?     // overrides platform default
  customLabel   String?  // rename for their context
  notes         String?
  createdAt     DateTime @default(now())

  category      PlatformCatalogCategory @relation(fields: [categoryId], references: [id])

  @@unique([institutionId, categoryId])
  @@map("institution_catalog_overrides")
}

// ═══════════════════════════════════════════════════════════════════════════
// COMMUNITY TRUST INFRASTRUCTURE — v2.0
// ═══════════════════════════════════════════════════════════════════════════
// The foundational data model for TrustGrid as Community Trust Infrastructure.
// Everything revolves around the Trust Graph:
//   CommunityNode (hierarchy) → Membership → AuthorityAssignment →
//   TrustCredential → TrustPassport → Endorsement
// ═══════════════════════════════════════════════════════════════════════════

// ─── Enums ────────────────────────────────────────────────────────────────

enum CommunityNodeStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  REVOKED
}

enum MembershipType {
  RESIDENT
  WORKER
  VOLUNTEER
  ASSOCIATE
  AUTHORITY
  VISITOR
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
  TRANSFERRED
}

enum MembershipVerificationLevel {
  SELF_DECLARED     // Person claims membership
  PEER_VOUCHED      // Another member vouched
  AUTHORITY_ISSUED  // An authority role confirmed
  BIOMETRIC         // NIN verified + face matched
}

enum AuthorityAssignmentStatus {
  ACTIVE
  REVOKED
  EXPIRED
  SUSPENDED
}

enum TrustCredentialStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

enum OpportunityType {
  VOLUNTEER
  JOB
  PROJECT
  EVENT_STAFFING
  MINISTRY
  SERVICE_REQUEST
  INTERNSHIP
}

enum OpportunityStatus {
  DRAFT
  OPEN
  FILLED
  CLOSED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

// ─── Community Node Type ──────────────────────────────────────────────────
// Defines the hierarchy levels for a tenant.
// RCCG: Global → Continent → Country → Region → Province → Zone → Area → Parish
// Estate: Estate → Phase → Street → Block

model CommunityNodeType {
  id           String   @id @default(cuid())
  institutionId String
  name         String   // "Province", "Area", "Parish", "Estate", "Block"
  pluralName   String?  // "Provinces", "Areas", "Parishes"
  level        Int      // 1 = top, higher number = deeper
  icon         String?
  color        String?
  canVerifyChildren Boolean @default(true)
  canIssueCredentials Boolean @default(true)
  canPublishOpportunities Boolean @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  nodes        CommunityNode[]

  @@unique([institutionId, level])
  @@map("community_node_types")
}

// ─── Community Node ───────────────────────────────────────────────────────
// The core hierarchical unit. Every organized community is a node.

model CommunityNode {
  id              String              @id @default(cuid())
  institutionId   String
  typeId          String
  name            String
  slug            String
  description     String?
  externalCode    String?             // e.g. RCCG parish code
  logoUrl         String?
  address         String?
  city            String?
  state           String?
  country         String              @default("NG")

  // Hierarchy
  parentId        String?
  depth           Int                 @default(0)

  // Verification chain
  status          CommunityNodeStatus @default(PENDING_VERIFICATION)
  verifiedById    String?             // which node verified this node
  verifiedAt      DateTime?
  verificationNotes String?

  // Trust metrics (computed/cached)
  memberCount     Int                 @default(0)
  activeCredentialCount Int           @default(0)
  avgTrustScore   Float?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       String?

  type            CommunityNodeType   @relation(fields: [typeId], references: [id])
  parent          CommunityNode?      @relation("NodeHierarchy", fields: [parentId], references: [id])
  children        CommunityNode[]     @relation("NodeHierarchy")
  memberships     Membership[]
  authorityAssignments AuthorityAssignment[]
  opportunities   Opportunity[]
  issuedCredentials TrustCredential[] @relation("IssuingNode")
  verifiedNodes   CommunityNode[]     @relation("NodeVerification")
  verifyingNode   CommunityNode?      @relation("NodeVerification", fields: [verifiedById], references: [id])

  @@unique([institutionId, slug])
  @@index([institutionId, parentId])
  @@index([institutionId, status])
  @@map("community_nodes")
}

// ─── Membership ───────────────────────────────────────────────────────────
// A person's verified belonging to a Community Node.

model Membership {
  id                  String                    @id @default(cuid())
  nodeId              String
  userId              String
  institutionId       String
  type                MembershipType            @default(RESIDENT)
  status              MembershipStatus          @default(PENDING)
  verificationLevel   MembershipVerificationLevel @default(SELF_DECLARED)

  // Who verified this membership
  verifiedById        String?                   // userId of the authority who confirmed
  verifiedAt          DateTime?
  verificationNotes   String?

  // Lifecycle
  joinedAt            DateTime                  @default(now())
  expiresAt           DateTime?
  revokedAt           DateTime?
  revokedReason       String?
  transferredToNodeId String?

  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  node                CommunityNode             @relation(fields: [nodeId], references: [id])

  @@unique([nodeId, userId])
  @@index([userId, institutionId])
  @@index([nodeId, status])
  @@map("memberships")
}

// ─── Authority Role ───────────────────────────────────────────────────────
// Defines what a role can do within a community node.

model AuthorityRole {
  id                    String   @id @default(cuid())
  institutionId         String
  name                  String   // "Parish Pastor", "Area Coordinator", "Estate Manager"
  description           String?
  level                 Int      @default(0)  // higher = more authority

  // Permissions
  canEndorseMemberships   Boolean @default(false)
  canIssueTrustCredentials Boolean @default(false)
  canVerifyChildNodes     Boolean @default(false)
  canPublishOpportunities Boolean @default(true)
  canApproveApplications  Boolean @default(false)
  canAssignRoles          Boolean @default(false)  // can delegate to lower-level roles
  canViewPrivateData      Boolean @default(false)
  canManageIncidents      Boolean @default(true)
  canBlacklist            Boolean @default(false)

  nodeTypeScope String?   // null = any node type, or restrict to specific type
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignments   AuthorityAssignment[]

  @@unique([institutionId, name])
  @@map("authority_roles")
}

// ─── Authority Assignment ─────────────────────────────────────────────────
// Assigns an authority role to a person at a specific community node.

model AuthorityAssignment {
  id            String                  @id @default(cuid())
  userId        String
  roleId        String
  nodeId        String
  institutionId String

  // Who granted this assignment
  grantedById   String
  grantedAt     DateTime                @default(now())

  status        AuthorityAssignmentStatus @default(ACTIVE)
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedById   String?
  revokedReason String?

  notes         String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  role          AuthorityRole           @relation(fields: [roleId], references: [id])
  node          CommunityNode           @relation(fields: [nodeId], references: [id])

  @@index([userId, institutionId, status])
  @@index([nodeId, status])
  @@map("authority_assignments")
}

// ─── Trust Passport ───────────────────────────────────────────────────────
// The portable, verifiable identity document for every person in TrustGrid.
// One passport per person. Globally unique passport code.

model TrustPassport {
  id             String   @id @default(cuid())
  passportCode   String   @unique    // TGP-92A81 — human-readable, URL-safe
  userId         String   @unique    // one passport per person
  institutionId  String

  // Public verification
  isPublic       Boolean  @default(true)  // whether verify URL works publicly
  verifyUrl      String?  // https://verify.trustgrid.ng/TGP-92A81
  qrCodeData     String?  // base64 QR code image

  // Validity
  issuedAt       DateTime @default(now())
  expiresAt      DateTime?
  lastVerifiedAt DateTime?
  status         TrustCredentialStatus @default(ACTIVE)

  // Cached summary (updated on trust events)
  trustScore     Float    @default(0)
  trustGrade     String   @default("F")
  credentialCount Int     @default(0)
  endorsementCount Int    @default(0)
  primaryCommunity String?  // name of primary community node
  primaryRole    String?    // most significant authority role

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  credentials    TrustCredential[]

  @@index([institutionId])
  @@map("trust_passports")
}

// ─── Trust Credential ─────────────────────────────────────────────────────
// A specific verifiable credential on a Trust Passport.
// Examples: "Verified Parish Member", "RCCG Convention Volunteer 2026",
//           "Certified Electrician (COREN)", "Estate Committee Member"

model TrustCredential {
  id              String               @id @default(cuid())
  passportId      String
  institutionId   String

  credentialType  String               // "VERIFIED_RESIDENT", "PARISH_MEMBER", "CERTIFIED_ELECTRICIAN"
  label           String               // Human-readable: "Verified Parish Member"
  description     String?
  category        String?              // "MEMBERSHIP", "PROFESSIONAL", "COMMUNITY_ROLE", "EVENT"

  // Issuing authority
  issuingNodeId   String?              // community node that issued this
  issuingUserId   String?              // authority who issued it
  issuingRoleName String?              // role name of issuer

  status          TrustCredentialStatus @default(ACTIVE)
  issuedAt        DateTime             @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedById     String?
  revokedReason   String?

  // Verification
  verifyUrl       String?              // deep link to verify this specific credential
  metadata        Json                 @default("{}")

  passport        TrustPassport        @relation(fields: [passportId], references: [id])
  issuingNode     CommunityNode?       @relation("IssuingNode", fields: [issuingNodeId], references: [id])

  @@index([passportId, status])
  @@index([institutionId, credentialType])
  @@map("trust_credentials")
}

// ─── Opportunity ─────────────────────────────────────────────────────────
// Trust-gated call to action published by a community node.

model Opportunity {
  id              String          @id @default(cuid())
  institutionId   String
  publishingNodeId String

  type            OpportunityType
  title           String
  description     String
  location        String?
  startDate       DateTime?
  endDate         DateTime?
  slotsAvailable  Int?
  slotsFilled     Int             @default(0)

  // Trust gate — who can see and apply
  requiresMembership Boolean      @default(true)
  requiredNodeIds    String[]     // must be member of at least one of these nodes
  minimumTrustScore  Float?
  requiredCredentials String[]    // credential types required
  requiredEndorsementTypes String[] // endorsement types required
  noOpenIncidents    Boolean      @default(false)
  maxIncidentAge     Int?         // max days since last incident

  // Skills
  requiredSkills  String[]
  categoryIds     String[]

  status          OpportunityStatus @default(DRAFT)
  publishedAt     DateTime?
  closedAt        DateTime?

  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  publishingNode  CommunityNode   @relation(fields: [publishingNodeId], references: [id])
  applications    OpportunityApplication[]

  @@index([institutionId, status])
  @@index([publishingNodeId, status])
  @@map("opportunities")
}

// ─── Opportunity Application ──────────────────────────────────────────────
model OpportunityApplication {
  id             String            @id @default(cuid())
  opportunityId  String
  applicantId    String            // userId
  institutionId  String
  status         ApplicationStatus @default(PENDING)
  appliedAt      DateTime          @default(now())
  reviewedAt     DateTime?
  reviewedById   String?
  reviewNotes    String?
  message        String?

  opportunity    Opportunity       @relation(fields: [opportunityId], references: [id])

  @@unique([opportunityId, applicantId])
  @@map("opportunity_applications")
}
